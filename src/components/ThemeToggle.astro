---
---

<div class="flex items-center gap-1">
  <!-- Day/Night Toggle Button -->
  <button
    id="theme-toggle"
    type="button"
    class="relative inline-flex items-center justify-center rounded-full h-8 w-8 text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
    aria-label="Toggle dark mode"
  >
    <!-- Sun Icon -->
    <svg
      id="theme-toggle-sun"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="h-[1.2rem] w-[1.2rem] icon-sun"
    >
      <circle cx="12" cy="12" r="4"></circle>
      <path d="M12 2v2"></path>
      <path d="M12 20v2"></path>
      <path d="m4.93 4.93 1.41 1.41"></path>
      <path d="m17.66 17.66 1.41 1.41"></path>
      <path d="M2 12h2"></path>
      <path d="M20 12h2"></path>
      <path d="m6.34 17.66-1.41 1.41"></path>
      <path d="m19.07 4.93-1.41 1.41"></path>
    </svg>

    <!-- Moon Icon -->
    <svg
      id="theme-toggle-moon"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="absolute h-[1.2rem] w-[1.2rem] icon-moon"
    >
      <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
    </svg>
  </button>

  <!-- Hacker Theme Toggle Button -->
  <button
    id="hacker-toggle"
    type="button"
    class="relative inline-flex items-center justify-center rounded-full h-8 w-8 text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
    aria-label="Toggle hacker mode"
  >
    <!-- Terminal Icon -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="h-[1.2rem] w-[1.2rem]"
    >
      <polyline points="4 17 10 11 4 5"></polyline>
      <line x1="12" y1="19" x2="20" y2="19"></line>
    </svg>
  </button>
</div>

<style>
  /* Sun/Moon transition styles */
  .icon-sun, .icon-moon {
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  
  /* Default (Light mode) */
  .icon-sun { opacity: 1; transform: scale(1) rotate(0deg); }
  .icon-moon { opacity: 0; transform: scale(0) rotate(90deg); }

  /* Dark mode */
  :global(.dark) .icon-sun { opacity: 0; transform: scale(0) rotate(-90deg); }
  :global(.dark) .icon-moon { opacity: 1; transform: scale(1) rotate(0deg); }

  /* Active Hacker button styling */
  #hacker-toggle {
    border: 1px solid transparent;
  }
  :global(.hacker) #hacker-toggle {
    color: var(--primary);
    background-color: color-mix(in oklab, var(--primary) 10%, transparent);
    border-color: color-mix(in oklab, var(--primary) 20%, transparent);
  }
</style>

<script>
  function setupThemeToggles() {
    const themeToggle = document.getElementById('theme-toggle');
    const hackerToggle = document.getElementById('hacker-toggle');
    
    if (themeToggle) {
      themeToggle.addEventListener('click', () => {
        const element = document.documentElement;
        element.classList.toggle('dark');
        const isDark = element.classList.contains('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    }

    if (hackerToggle) {
      hackerToggle.addEventListener('click', () => {
        const element = document.documentElement;
        element.classList.toggle('hacker');
        const isHacker = element.classList.contains('hacker');
        localStorage.setItem('hacker', isHacker ? 'true' : 'false');
      });
    }
  }

  // Setup on page load
  setupThemeToggles();

  // Setup on View Transitions navigation
  document.addEventListener('astro:after-swap', setupThemeToggles);
</script>
