---
---

<button
  id="theme-toggle"
  type="button"
  class="relative inline-flex items-center justify-center rounded-full h-8 w-8 text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
  aria-label="Toggle theme"
>
  <!-- Sun Icon -->
  <svg
    id="theme-toggle-sun"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="h-[1.2rem] w-[1.2rem] icon-sun"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path>
    <path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path>
    <path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M2 12h2"></path>
    <path d="M20 12h2"></path>
    <path d="m6.34 17.66-1.41 1.41"></path>
    <path d="m19.07 4.93-1.41 1.41"></path>
  </svg>

  <!-- Moon Icon -->
  <svg
    id="theme-toggle-moon"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="absolute h-[1.2rem] w-[1.2rem] icon-moon"
  >
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>

  <!-- Terminal Icon (Hacker Mode) -->
  <svg
    id="theme-toggle-terminal"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="absolute h-[1.2rem] w-[1.2rem] icon-terminal"
  >
    <polyline points="4 17 10 11 4 5"></polyline>
    <line x1="12" y1="19" x2="20" y2="19"></line>
  </svg>
</button>

<style>
  .icon-sun, .icon-moon, .icon-terminal {
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  
  /* Default (Light Mode) */
  .icon-sun { opacity: 1; transform: scale(1) rotate(0deg); }
  .icon-moon { opacity: 0; transform: scale(0) rotate(90deg); }
  .icon-terminal { opacity: 0; transform: scale(0) rotate(90deg); }

  /* Dark Mode */
  :global(.dark) .icon-sun { opacity: 0; transform: scale(0) rotate(-90deg); }
  :global(.dark) .icon-moon { opacity: 1; transform: scale(1) rotate(0deg); }
  :global(.dark) .icon-terminal { opacity: 0; transform: scale(0) rotate(90deg); }

  /* Hacker Mode */
  :global(.hacker) .icon-sun { opacity: 0; transform: scale(0) rotate(-90deg); }
  :global(.hacker) .icon-moon { opacity: 0; transform: scale(0) rotate(-90deg); }
  :global(.hacker) .icon-terminal { opacity: 1; transform: scale(1) rotate(0deg); }
</style>

<script>
  function setupThemeToggle() {
    const themeToggle = document.getElementById('theme-toggle');
    if (themeToggle) {
      // Rebind click listener
      themeToggle.addEventListener('click', () => {
        const element = document.documentElement;
        let nextTheme = 'light';
        
        if (element.classList.contains('dark')) {
          nextTheme = 'hacker';
        } else if (element.classList.contains('hacker')) {
          nextTheme = 'light';
        } else {
          nextTheme = 'dark';
        }
        
        element.classList.remove('dark', 'hacker');
        if (nextTheme === 'dark') {
          element.classList.add('dark');
        } else if (nextTheme === 'hacker') {
          element.classList.add('hacker');
        }
        
        localStorage.setItem('theme', nextTheme);
      });
    }
  }

  // Setup on page load
  setupThemeToggle();

  // Setup on View Transitions navigation
  document.addEventListener('astro:after-swap', setupThemeToggle);
</script>
