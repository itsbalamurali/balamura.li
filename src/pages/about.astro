---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Me" description="Learn more about Balamurali Pandranki. Enterprise Architect, Leader, Cloud Native enthusiast.">
  <div class="flex flex-col gap-10 max-w-4xl mx-auto">
    <!-- Header Section -->
    <section class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
      <div class="flex flex-col gap-4">
        <h1 class="text-4xl font-extrabold tracking-tight lg:text-5xl">Balamurali Pandranki</h1>
        <h2 class="text-2xl font-semibold text-muted-foreground">Enterprise Architect & Management Professional</h2>
        <div class="flex flex-wrap gap-4 text-sm text-muted-foreground">
          <span class="flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            Tallinn, Estonia
          </span>
          <span class="flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            balamurali@live.com
          </span>
        </div>
        <p class="text-lg leading-relaxed max-w-2xl">
          An executive leader & architect with more than a decade of experience architecting, building, developing, 
          managing, and leading proprietary enterprise products, cloud-native software, cross-functional teams & business aspects. 
          Passionate about using various technologies to design, develop, and deploy real enterprise-class software.
        </p>
        <div class="flex flex-wrap gap-3 mt-2">
          <a
            href="https://github.com/itsbalamurali"
            target="_blank"
            class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-4 py-2 shadow-sm transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
              <path d="M9 18c-4.51 2-5-2-7-2"></path>
            </svg>
            GitHub
          </a>
          <a
            href="https://twitter.com/itsbalamurali"
            target="_blank"
            class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-4 py-2 shadow-sm transition-colors"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="mr-2 h-3.5 w-3.5">
              <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z" />
            </svg>
            X
          </a>
          <a
            href="https://linkedin.com/in/itsbalamurali"
            target="_blank"
            class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-4 py-2 shadow-sm transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect width="4" height="12" x="2" y="9"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
            LinkedIn
          </a>
          <a
            href="https://balamura.li"
            target="_blank"
            class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-4 py-2 shadow-sm transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
              <path d="M2 12h20"></path>
            </svg>
            Website
          </a>
          <a
            href="mailto:balamurali@live.com"
            class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent hover:text-accent-foreground h-9 px-4 py-2 shadow-sm transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            Email
          </a>
        </div>
      </div>
    </section>

    <hr class="border-border" />

    <!-- Skills Section -->
    <section class="flex flex-col gap-4">
      <h3 class="text-2xl font-bold tracking-tight">Skills & Technology</h3>
      <div class="grid gap-6 md:grid-cols-2">
        <!-- Card 1: Programming / Languages -->
        <div class="rounded-xl border bg-card text-card-foreground shadow">
          <div class="flex flex-col space-y-1.5 p-6">
            <h3 class="font-semibold leading-none tracking-tight text-lg">Programming / Languages</h3>
          </div>
          <div class="p-6 pt-0 flex flex-wrap gap-2">
            {["NodeJS/Javascript", "Java", "Golang", "Python", "C/C++", "Ruby", "Rust", "Typescript", "Dart", "Kotlin", "Bash"].map(skill => (
              <span class="inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold bg-secondary text-secondary-foreground transition-colors">{skill}</span>
            ))}
          </div>
        </div>

        <!-- Card 2: AI / ML & Modern Stack -->
        <div class="rounded-xl border bg-card text-card-foreground shadow">
          <div class="flex flex-col space-y-1.5 p-6">
            <h3 class="font-semibold leading-none tracking-tight text-lg">AI / ML & Modern Stack</h3>
          </div>
          <div class="p-6 pt-0 flex flex-wrap gap-2">
            {["LLMs (OpenAI, Gemini, Claude)", "Model Context Protocol (MCP)", "MLOps & LLMOps", "LangChain / LlamaIndex", "Vector DBs (pgvector, Pinecone)", "RAG Architectures", "Prompt Engineering", "Fine-Tuning & Quantization"].map(skill => (
              <span class="inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold bg-secondary text-secondary-foreground transition-colors">{skill}</span>
            ))}
          </div>
        </div>

        <!-- Card 3: Cloud & Infrastructure -->
        <div class="rounded-xl border bg-card text-card-foreground shadow">
          <div class="flex flex-col space-y-1.5 p-6">
            <h3 class="font-semibold leading-none tracking-tight text-lg">Cloud & Infrastructure</h3>
          </div>
          <div class="p-6 pt-0 flex flex-wrap gap-2">
            {["AWS", "Google Cloud", "Digital Ocean", "Azure", "Heroku", "Docker", "Kubernetes", "Ansible", "Terraform", "Linux"].map(skill => (
              <span class="inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold bg-secondary text-secondary-foreground transition-colors">{skill}</span>
            ))}
          </div>
        </div>

        <!-- Card 4: Databases & Mobile -->
        <div class="rounded-xl border bg-card text-card-foreground shadow">
          <div class="flex flex-col space-y-1.5 p-6">
            <h3 class="font-semibold leading-none tracking-tight text-lg">Databases & Mobile</h3>
          </div>
          <div class="p-6 pt-0 flex flex-wrap gap-2">
            {["PostgreSQL", "MySQL", "MongoDB", "Redis", "Cassandra", "BigQuery", "Android Studio", "Kotlin", "Swift", "Flutter", "React Native"].map(skill => (
              <span class="inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold bg-secondary text-secondary-foreground transition-colors">{skill}</span>
            ))}
          </div>
        </div>

        <!-- Card 5: Certifications (Spanned) -->
        <div class="rounded-xl border bg-card text-card-foreground shadow md:col-span-2">
          <div class="flex flex-col space-y-1.5 p-6">
            <h3 class="font-semibold leading-none tracking-tight text-lg">Certifications</h3>
          </div>
          <div class="p-6 pt-0 flex flex-col gap-2 text-sm">
            <ul class="list-disc pl-4 space-y-1 text-muted-foreground">
              <li>Google Cloud Certified Professional Cloud Architect</li>
              <li>AWS Certified Solutions Architect</li>
              <li>CNCF Certified Kubernetes Administrator & Security Specialist</li>
              <li>Microsoft Certified Azure Architect Expert</li>
              <li>EC-Council Certified Ethical Hacker</li>
              <li>EC-Council Certified Chief Information Security Officer (CISO)</li>
              <li>PMI Certified Project Management Professional</li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
